{
  "name": "three-pixel-font",
  "version": "1.0.0",
  "license": "MIT",
  "type": "module",
  "main": "./lib/index.js",
  "module": "./lib/index.js",
  "types": "./types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./lib/index.js"
    },
    "./webgl": {
      "types": "./types/webgl.d.ts",
      "import": "./lib/webgl.js"
    },
    "./webgpu": {
      "types": "./types/webgpu.d.ts",
      "import": "./lib/webgpu.js"
    }
  },
  "files": [
    "lib",
    "types",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "description": "Pixel-perfect bitmap font rendering for Three.js WebGL and WebGPU",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bunnybones1/three-pixel-font.git"
  },
  "scripts": {
    "build": "npm run clean && npm run build:js && npm run build:types",
    "build:js": "node ./scripts/build.mjs",
    "build:types": "tsc --project tsconfig.types.json",
    "clean": "node ./scripts/clean.mjs",
    "prepack": "npm run build",
    "test": "npm run typecheck && npm run build && node --test test/*.test.mjs",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "three": ">=0.185.0 <0.186.0"
  },
  "devDependencies": {
    "@types/three": "^0.185.1",
    "esbuild": "^0.28.1",
    "three": "^0.185.1",
    "typescript": "^6.0.3"
  },
  "bugs": {
    "url": "https://github.com/bunnybones1/three-pixel-font/issues"
  },
  "homepage": "https://github.com/bunnybones1/three-pixel-font#readme",
  "keywords": [
    "bitmap-font",
    "font",
    "gamedev",
    "pixel-font",
    "threejs",
    "webgpu"
  ],
  "author": "Tomasz Dysinski"
}
